# E-Learning Frontend - Environment Configuration Example
# Copy this file to .env and adjust as needed (though Angular usually uses environment.ts files)

# --- API Endpoints ---
# Team Ariana (Content, Lessons, Quizzes) - Usually routed through the Gateway on port 8082
QUIZ_API_URL=http://localhost:8082
LESSON_API_URL=http://localhost:8082

# Team Moisa (User Platform, Progress, Payments) - Can be called directly on 8083 or via Gateway on 8082
# Note: Direct calls to 8083 require CORS configuration in the backend service.
USER_PLATFORM_API_URL=http://localhost:8082

# --- Keycloak Configuration ---
KEYCLOAK_URL=https://keycloak-26-0-7-vb34.onrender.com/
KEYCLOAK_REALM=elearning
KEYCLOAK_CLIENT_ID=elearning-angular

# --- Ports Summary ---
# 8082: API Gateway (Ariana Repo) - RECOMMENDED ENTRY POINT
# 8081: Content Service (Ariana Repo)
# 8083: User Platform Service (Moisa Repo)
